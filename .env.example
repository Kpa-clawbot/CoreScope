# CoreScope environment configuration
# Copy to .env and customize. Keep real passwords and broker credentials out
# of git.

# --- live.meshcore.ca production shape ---
# These defaults mirror the current live host layout observed on
# live.meshcore.ca. The app replaces the existing "corescope" container on
# host ports 80/443 when used with docker-compose.live.yml.

CORESCOPE_IMAGE=corescope:latest

PROD_HTTP_PORT=80
PROD_HTTPS_PORT=443

PROD_CONFIG_FILE=/opt/docker/corescope/data/corescope/config.json
PROD_DATA_DIR=/opt/docker/corescope/data/corescope/data
PROD_CADDYFILE=/opt/docker/corescope/data/caddy/config/Caddyfile
PROD_CADDY_DATA_DIR=/opt/docker/corescope/data/caddy/app
PROD_POSTGRES_DATA_DIR=/opt/docker/corescope/data/postgres

# Production uses the external MeshCore MQTT broker config already mounted at
# PROD_CONFIG_FILE. Do not publish 1883 for live.meshcore.ca.
DISABLE_MOSQUITTO=true
DISABLE_CADDY=false

# Postgres is primary after migration. If you change POSTGRES_PASSWORD, update
# DATABASE_URL to match.
DB_DRIVER=postgres
DATABASE_URL=postgres://corescope:corescope-change-me@postgres:5432/corescope?sslmode=disable
DB_PATH=/app/data/meshcore.db
POSTGRES_DB=corescope
POSTGRES_USER=corescope
POSTGRES_PASSWORD=corescope-change-me

# Public profile values are safe placeholders. Put real MQTT credentials only
# in the mounted live config or in an untracked env file.
PUBLIC_BASE_URL=https://live.meshcore.ca
PUBLIC_MODE=public
CORESCOPE_CONFIG_PROFILE=config.live.meshcore.ca.example.json
MESHCORE_MQTT_TOKEN=
MESHCORE_MQTT_USERNAME=
MESHCORE_MQTT_PASSWORD=

# --- staging / local validation ---
STAGING_DATA_DIR=~/meshcore-staging-data
STAGING_GO_HTTP_PORT=82
STAGING_GO_MQTT_PORT=1885

# docker-compose.dev.yml remains available for isolated local development, but
# it is not the live.meshcore.ca deployment target for this repo.
